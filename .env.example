# secscan — Environment-Variablen (Beispiel)
# Kopiere diese Datei nach `.env` und passe die Werte an.
# Alle Variablen werden von `app/config.py` (pydantic-settings) eingelesen.

# ---------------------------------------------------------------------------
# Pflicht
# ---------------------------------------------------------------------------

# Fernet-Schlüssel zum Verschlüsseln der LLM-API-Keys in der DB.
# 32 Bytes Base64-kodiert. Erzeugen z.B. mit:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Ohne diesen Wert verweigert die App den Start.
SECSCAN_ENCRYPTION_KEY=

# Flask-Session-Cookie-Geheimnis. Hochentropischer Zufallswert.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECSCAN_SECRET_KEY=

# Postgres-Connection-URL (async-fähiger psycopg-Treiber).
# Beispiel für docker-compose:
SECSCAN_DATABASE_URL=postgresql+psycopg://secscan:secscan@db:5432/secscan

# ---------------------------------------------------------------------------
# Postgres-Container (nur fuer docker-compose)
# ---------------------------------------------------------------------------

POSTGRES_USER=secscan
POSTGRES_PASSWORD=secscan
POSTGRES_DB=secscan

# ---------------------------------------------------------------------------
# Optional — DoS- und Body-Limits (Defaults siehe ARCHITECTURE.md §9)
# ---------------------------------------------------------------------------

# Maximale Wire-Body-Groesse in MB fuer /api/scans (Default 10).
SECSCAN_MAX_BODY_MB=10

# Maximale dekomprimierte Body-Groesse in MB fuer /api/scans (Default 100).
SECSCAN_MAX_DECOMPRESSED_MB=100

# ---------------------------------------------------------------------------
# Optional — Rate-Limits (flask-limiter-Format: "<n>/<period>")
# ---------------------------------------------------------------------------

SECSCAN_RATELIMIT_REGISTER=10/minute
SECSCAN_RATELIMIT_LOGIN=5/minute
SECSCAN_RATELIMIT_SCANS_UNAUTH=20/minute
SECSCAN_RATELIMIT_SCANS_AUTH=60/hour

# ---------------------------------------------------------------------------
# Optional — Gunicorn-Worker (im Container)
# ---------------------------------------------------------------------------

SECSCAN_GUNICORN_WORKERS=2
SECSCAN_GUNICORN_TIMEOUT=120

# ---------------------------------------------------------------------------
# Optional — Logging
# ---------------------------------------------------------------------------

# Log-Level: DEBUG, INFO, WARNING, ERROR
SECSCAN_LOG_LEVEL=INFO
