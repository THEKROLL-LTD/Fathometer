# fathometer — Environment-Variablen (Beispiel)
# Kopiere diese Datei nach `.env` und passe die Werte an.
# Alle Variablen werden von `app/config.py` (pydantic-settings) eingelesen.

# ---------------------------------------------------------------------------
# Pflicht
# ---------------------------------------------------------------------------

# Fernet-Schlüssel zum Verschlüsseln der LLM-API-Keys in der DB.
# 32 Bytes Base64-kodiert. Erzeugen z.B. mit:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Ohne diesen Wert verweigert die App den Start.
FM_ENCRYPTION_KEY=

# Flask-Session-Cookie-Geheimnis. Hochentropischer Zufallswert.
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
FM_SECRET_KEY=

# Postgres-Connection-URL (async-fähiger psycopg-Treiber).
# Beispiel für docker-compose:
FM_DATABASE_URL=postgresql+psycopg://fathometer:fathometer@db:5432/fathometer

# Extern sichtbare Backend-URL inkl. Schema. Block N / v0.7.1.
# Bevorzugt vor `request.host_url` im Bootstrap-Installer (`/install.sh`)
# und im UI-Tooltip-Update-Befehl. Ohne diesen Wert sieht Flask hinter
# einem TLS-terminierenden Reverse-Proxy nur das interne `http://`-Schema
# (auch mit ProxyFix nur, wenn der Proxy `X-Forwarded-Proto $scheme`
# setzt). Setze die Variable in Production immer auf die externe HTTPS-URL.
# Trailing-Slash wird abgeschnitten.
FM_PUBLIC_URL=

# ---------------------------------------------------------------------------
# Postgres-Container (nur fuer docker-compose)
# ---------------------------------------------------------------------------

POSTGRES_USER=fathometer
POSTGRES_PASSWORD=fathometer
POSTGRES_DB=fathometer

# ---------------------------------------------------------------------------
# Optional — DoS- und Body-Limits (Defaults siehe ARCHITECTURE.md §9)
# ---------------------------------------------------------------------------

# Maximale Wire-Body-Groesse in MB fuer /api/scans (Default 10).
FM_MAX_BODY_MB=10

# Maximale dekomprimierte Body-Groesse in MB fuer /api/scans (Default 100).
FM_MAX_DECOMPRESSED_MB=100

# ---------------------------------------------------------------------------
# Optional — Rate-Limits (flask-limiter-Format: "<n>/<period>")
# ---------------------------------------------------------------------------

FM_RATELIMIT_REGISTER=10/minute
FM_RATELIMIT_LOGIN=5/minute
FM_RATELIMIT_SCANS_UNAUTH=20/minute
FM_RATELIMIT_SCANS_AUTH=60/hour

# ---------------------------------------------------------------------------
# Optional — Gunicorn-Worker (im Container)
# ---------------------------------------------------------------------------

# Worker-Prozesse. 2 reicht fuer Single-User-Self-Hosting.
FM_GUNICORN_WORKERS=2

# Threads pro Worker. MUSS > 1 sein — die App hat SSE-Endpoints, die
# bei `--worker-class gthread` pro Stream einen Thread binden. Default
# 8 erlaubt 2 x 8 = 16 gleichzeitige Connections (siehe ADR-0015).
FM_GUNICORN_THREADS=8

FM_GUNICORN_TIMEOUT=120

# ---------------------------------------------------------------------------
# Optional — Logging
# ---------------------------------------------------------------------------

# Log-Level: DEBUG, INFO, WARNING, ERROR
FM_LOG_LEVEL=INFO
