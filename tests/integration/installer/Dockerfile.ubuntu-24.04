# Block N (ADR-0021, Task #18) — Installer-E2E auf Ubuntu 24.04.
#
# Minimaler Container fuer `tests/integration/test_installer_e2e.py`.
# Nicht fuer Produktiv-Use — pinst keine secscan-Komponenten ein, nur die
# OS-Tools, die der Installer braucht (bash, curl, sudo, ca-certificates).
#
# Run via `make test-installer` oder direkt:
#   docker build -t secscan-installer-test:ubuntu-24.04 \
#     -f tests/integration/installer/Dockerfile.ubuntu-24.04 .
#   docker run --rm -e SECSCAN_URL=http://host.docker.internal:8000 \
#     -e SECSCAN_UNATTENDED=1 -e SECSCAN_MASTER_KEY=test \
#     secscan-installer-test:ubuntu-24.04
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends \
        bash \
        curl \
        sudo \
        ca-certificates \
        gnupg \
        systemd \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /tmp/installer
CMD ["/bin/bash", "-c", "curl -fsSL ${SECSCAN_URL}/install.sh | bash"]
